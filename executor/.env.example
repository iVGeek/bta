# ── Server ────────────────────────────────────────
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8080
WEBHOOK_SECRET=your_secret_here

# ── Mode ──────────────────────────────────────────
# Set to false when ready for live trading
DRY_RUN=true

# ── Claude AI ─────────────────────────────────────
# Get your key at https://console.anthropic.com/
CLAUDE_API_KEY=

# ── Risk ──────────────────────────────────────────
MAX_POSITION_PCT=5.0
MAX_DAILY_TRADES=20
MAX_DAILY_LOSS_PCT=10.0
DEFAULT_LEVERAGE=1

# ── Exchanges ─────────────────────────────────────
# Comma-separated: binance,bybit,okx,bitget,gate
ACTIVE_EXCHANGES=binance
DEFAULT_EXCHANGE=binance

# ── Binance ───────────────────────────────────────
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true

# ── Bybit ─────────────────────────────────────────
BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_TESTNET=true

# ── OKX ───────────────────────────────────────────
OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=
OKX_TESTNET=true

# ── Bitget ────────────────────────────────────────
BITGET_API_KEY=
BITGET_API_SECRET=
BITGET_PASSPHRASE=
BITGET_TESTNET=true

# ── Gate.io ───────────────────────────────────────
GATE_API_KEY=
GATE_API_SECRET=
