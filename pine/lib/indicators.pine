//@version=6
// iVGeek Custom Indicators Library v3.0
// Advanced indicators, Ichimoku, candlestick patterns, and market analysis
// ============================================================
library("iVGeek Indicators")

// === Market Regime Detection ===
// @param close: close price series
// @param high: high price series
// @param low: low price series
// @returns: tuple (trend: 1=bull, -1=bear, 0=neutral; volatility: 0=low, 1=normal, 2=high)
export marketRegime(float close, float high, float low) =>
    ema20  = ta.ema(close, 20)
    ema50  = ta.ema(close, 50)
    ema200 = ta.ema(close, 200)
    atr14  = ta.atr(14)
    atrPct = atr14 / close * 100
    avgAtr = ta.sma(atrPct, 50)

    trend = close > ema50 and ema50 > ema200 ? 1 : close < ema50 and ema50 < ema200 ? -1 : 0
    vol   = atrPct < avgAtr * 0.8 ? 0 : atrPct > avgAtr * 1.5 ? 2 : 1
    [trend, vol]

// === Support & Resistance Levels ===
// Fractal-based S/R detection
// @param high: high price series
// @param low: low price series
// @param lookback: periods to look back
// @returns: tuple (resistLevel, supportLevel, isResist, isSupport)
export fractalSR(float high, float low, int lookback) =>
    isResist  = high == ta.highest(high, lookback * 2 + 1) and high[lookback] == ta.highest(high, lookback * 2 + 1)
    isSupport = low == ta.lowest(low, lookback * 2 + 1) and low[lookback] == ta.lowest(low, lookback * 2 + 1)

    resistLevel = ta.valuewhen(isResist, high, 0)
    supportLevel = ta.valuewhen(isSupport, low, 0)

    [resistLevel, supportLevel, isResist, isSupport]

// === Trend Strength Index ===
// Combines ADX, EMA slope, and price position for a composite strength score (0-100)
// @param close: close price
// @param high: high price
// @param low: low price
// @returns: strength score 0-100
export trendStrength(float close, float high, float low) =>
    [_, _, adxVal] = ta.dmi(14, 14)
    ema20   = ta.ema(close, 20)
    ema50   = ta.ema(close, 50)
    emaSlope = (ema20 - ema20[5]) / ema20[5] * 100

    score = 0.0
    score += math.min(adxVal * 1.6, 40.0)
    score += math.min(math.abs(emaSlope) * 10, 30.0)
    score += close > ema50 ? 15.0 : 0.0
    score += close > ema20 ? 15.0 : 0.0

    math.min(score, 100.0)

// === Trend Strength (Extended) ===
// Detailed trend strength with custom EMAs and indicators
// @param close, ema9, ema21, ema50, ema200: price and EMA values
// @param adxVal, diPlus, diMinus: DMI values
// @param rsiVal: RSI value
// @returns: strength score 0-100
export trendStrengthEx(float close, float ema9, float ema21, float ema50, float ema200, float adxVal, float diPlus, float diMinus, float rsiVal) =>
    score = 0.0
    // EMA alignment (0-25)
    score += close > ema9 ? 5.0 : 0.0
    score += close > ema21 ? 5.0 : 0.0
    score += close > ema50 ? 5.0 : 0.0
    score += close > ema200 ? 5.0 : 0.0
    score += ema9 > ema21 and ema21 > ema50 ? 5.0 : 0.0
    // ADX component (0-30)
    score += math.min(adxVal * 1.2, 30.0)
    // DI direction (0-15)
    score += diPlus > diMinus ? 15.0 : 0.0
    // RSI position (0-15)
    score += rsiVal > 50 and rsiVal < 70 ? 15.0 : rsiVal > 50 ? 7.5 : 0.0
    // Price above EMA200 bonus (0-15)
    score += close > ema200 ? 15.0 : 0.0

    math.min(score, 100.0)

// === Volume Pressure Index ===
// Measures buying vs selling pressure using volume + price delta
// @param close: close price
// @param volume: volume
// @returns: VPI (-100 to +100)
export volumePressure(float close, float volume) =>
    delta = close - close[1]
    rawVpi = ta.sma(delta > 0 ? volume : delta < 0 ? -volume : 0, 14)
    avgVol = ta.sma(volume, 14)
    avgVol > 0 ? rawVpi / avgVol * 100 : 0.0

// === Volume Pressure Index (Extended) ===
// Detailed buying/selling pressure from OHLCV data
// @param open, high, low, close, volume: OHLCV data
// @returns: tuple (buyPressure, sellPressure) each 0-100
export volumePressureIndex(float open, float high, float low, float close, float volume) =>
    barRange = high - low
    buyVol = barRange > 0 ? volume * (close - low) / barRange : volume * 0.5
    sellVol = barRange > 0 ? volume * (high - close) / barRange : volume * 0.5
    avgBuy = ta.sma(buyVol, 14)
    avgSell = ta.sma(sellVol, 14)
    total = avgBuy + avgSell
    buyP = total > 0 ? avgBuy / total * 100 : 50.0
    sellP = total > 0 ? avgSell / total * 100 : 50.0
    [buyP, sellP]

// === Volatility Squeeze Detector ===
// Detects Bollinger Band / Keltner Channel squeeze
// @param close: close price
// @param high: high price
// @param low: low price
// @returns: 1=squeeze, 0=normal, -1=expansion
export squeezeDetector(float close, float high, float low) =>
    [bbU, bbM, bbL] = ta.bb(close, 20, 2.0)
    kcUpper = ta.ema(close, 20) + ta.atr(14) * 1.5
    kcLower = ta.ema(close, 20) - ta.atr(14) * 1.5

    bbWidth = bbU - bbL
    kcWidth = kcUpper - kcLower

    squeeze  = bbWidth < kcWidth ? 1 : 0
    expanded = bbWidth > kcWidth * 1.5 ? -1 : 0

    squeeze != 0 ? squeeze : expanded

// === Order Block Detector ===
// Detects potential institutional order blocks
// @param open: open price
// @param close: close price
// @param high: high price
// @param low: low price
// @returns: 1=bullish OB, -1=bearish OB, 0=none
export orderBlock(float open, float close, float high, float low) =>
    bullOB = low == ta.lowest(low, 5) and close > open and close[1] < open[1]
    bearOB = high == ta.highest(high, 5) and close < open and close[1] > open[1]
    bullOB ? 1 : bearOB ? -1 : 0

// === Liquidity Sweep Detector ===
// Detects stop hunts / liquidity grabs
// @param high: high price
// @param low: low price
// @param close: close price
// @param lookback: periods
// @returns: 1=bullish sweep, -1=bearish sweep, 0=none
export liquiditySweep(float high, float low, float close, int lookback) =>
    sweepHigh = high > ta.highest(high[1], lookback) and close < open
    sweepLow  = low < ta.lowest(low[1], lookback) and close > open
    sweepLow ? 1 : sweepHigh ? -1 : 0

// === Multi-Timeframe Confluence ===
// @param symbol: ticker
// @param tf1, tf2, tf3: timeframes to check
// @returns: confluence score (0-3)
export mtfConfluence(string symbol, string tf1, string tf2, string tf3) =>
    trend1 = request.security(symbol, tf1, close > ta.ema(close, 50))
    trend2 = request.security(symbol, tf2, close > ta.ema(close, 50))
    trend3 = request.security(symbol, tf3, close > ta.ema(close, 50))
    (trend1 ? 1 : 0) + (trend2 ? 1 : 0) + (trend3 ? 1 : 0)

// === Ichimoku Cloud ===
// Standard Ichimoku with Tenkan, Kijun, Senkou A/B, Chikou
// @param high: high price
// @param low: low price
// @param close: close price
// @returns: tuple (tenkan, kijun, senkouA, senkouB, chikou)
export ichimokuCloud(float high, float low, float close) =>
    tenkan  = (ta.highest(high, 9) + ta.lowest(low, 9)) / 2
    kijun   = (ta.highest(high, 26) + ta.lowest(low, 26)) / 2
    senkouA = (tenkan + kijun) / 2
    senkouB = (ta.highest(high, 52) + ta.lowest(low, 52)) / 2
    chikou  = close
    [tenkan, kijun, senkouA, senkouB, chikou]

// === Ichimoku Signal ===
// Returns cloud direction and TK cross
// @param high, low, close: price series
// @returns: tuple (cloudBull: 1/-1/0, tkCross: 1/-1/0, aboveCloud: bool)
export ichimokuSignal(float high, float low, float close) =>
    tenkan  = (ta.highest(high, 9) + ta.lowest(low, 9)) / 2
    kijun   = (ta.highest(high, 26) + ta.lowest(low, 26)) / 2
    senkouA = (tenkan + kijun) / 2
    senkouB = (ta.highest(high, 52) + ta.lowest(low, 52)) / 2
    cloudTop  = math.max(senkouA, senkouB)
    cloudBot  = math.min(senkouA, senkouB)
    aboveCloud = close > cloudTop
    belowCloud = close < cloudBot
    cloudBull  = senkouA > senkouB ? 1 : senkouA < senkouB ? -1 : 0
    tkCross    = tenkan > kijun and tenkan[1] <= kijun[1] ? 1 : tenkan < kijun and tenkan[1] >= kijun[1] ? -1 : 0
    [cloudBull, tkCross, aboveCloud, belowCloud]

// === Candlestick Pattern: Doji ===
// @param open, high, low, close: OHLC
// @returns: 1=bullish doji, -1=bearish doji, 0=none
export patternDoji(float open, float high, float low, float close) =>
    bodySize = math.abs(close - open)
    barSize  = high - low
    barSize > 0 ? (bodySize / barSize < 0.1 ? (close > open ? 1 : -1) : 0) : 0

// === Candlestick Pattern: Hammer / Inverted Hammer ===
// Bullish hammer: small body at top, long lower wick (2x+ body)
// Bearish inverted hammer: small body at bottom, long upper wick
// @param open, high, low, close: OHLC
// @returns: 1=bullish hammer, -1=shooting star, 0=none
export patternHammer(float open, float high, float low, float close) =>
    bodySize = math.abs(close - open)
    upperWick = high - math.max(open, close)
    lowerWick = math.min(open, close) - low
    barSize   = high - low
    barSize > 0 and bodySize > 0 ? (
        lowerWick >= bodySize * 2 and upperWick <= bodySize * 0.5 and close > open ? 1 :
        upperWick >= bodySize * 2 and lowerWick <= bodySize * 0.5 and close < open ? -1 : 0
    ) : 0

// === Candlestick Pattern: Bullish / Bearish Engulfing ===
// @param open1, close1, open0, close0: current and previous OHLC
// @param high0, low0: current bar
// @returns: 1=bullish engulfing, -1=bearish engulfing, 0=none
export patternEngulfing(float open1, float close1, float open0, float close0, float high0, float low0) =>
    prevBody = math.abs(close1 - open1)
    currBody = math.abs(close0 - open0)
    isBullEngulf = close1 < open1 and close0 > open0 and open0 <= close1 and close0 >= open1 and currBody > prevBody
    isBearEngulf = close1 > open1 and close0 < open0 and open0 >= close1 and close0 <= open1 and currBody > prevBody
    isBullEngulf ? 1 : isBearEngulf ? -1 : 0

// === Candlestick Pattern: Pin Bar ===
// Long wick rejection (wick > 2x body, in direction of rejection)
// @param open, high, low, close: OHLC
// @returns: 1=bullish pin (bullish rejection), -1=bearish pin (bearish rejection), 0=none
export patternPinBar(float open, float high, float low, float close) =>
    bodySize = math.abs(close - open)
    upperWick = high - math.max(open, close)
    lowerWick = math.min(open, close) - low
    barSize   = high - low
    barSize > 0 and bodySize > 0 ? (
        lowerWick > bodySize * 2.5 and lowerWick > upperWick * 2 ? 1 :
        upperWick > bodySize * 2.5 and upperWick > lowerWick * 2 ? -1 : 0
    ) : 0

// === Pattern Score (Composite) ===
// Scores all 5 patterns and returns composite signal
// @param open1, high1, low1, close1: previous bar OHLC
// @param open0, high0, low0, close0: current bar OHLC
// @returns: tuple (bullScore, bearScore) each 0-3
export patternScore(float open1, float high1, float low1, float close1, float open0, float high0, float low0, float close0) =>
    bullScore = 0.0
    bearScore = 0.0
    // Doji (neutral — adds to both sides as uncertainty)
    doji = patternDoji(open0, high0, low0, close0)
    bullScore += doji == 1 ? 1.0 : 0.0
    bearScore += doji == -1 ? 1.0 : 0.0
    // Hammer / Shooting Star
    hammer = patternHammer(open0, high0, low0, close0)
    bullScore += hammer == 1 ? 1.0 : 0.0
    bearScore += hammer == -1 ? 1.0 : 0.0
    // Engulfing
    engulf = patternEngulfing(open1, close1, open0, close0, high0, low0)
    bullScore += engulf == 1 ? 1.0 : 0.0
    bearScore += engulf == -1 ? 1.0 : 0.0
    // Pin Bar
    pin = patternPinBar(open0, high0, low0, close0)
    bullScore += pin == 1 ? 1.0 : 0.0
    bearScore += pin == -1 ? 1.0 : 0.0
    [bullScore, bearScore]
